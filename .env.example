# ==========================================
# FRONTEND CONFIGURATION (Vercel Environment Variables)
# ==========================================

# Supabase Client Details (used for front-end authentication and storage public uploads)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# URL of your Express API backend deployed on Render
# In local development: http://localhost:5000
# In production: https://your-backend-app.onrender.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# ==========================================
# BACKEND CONFIGURATION (Render Environment Variables)
# ==========================================

# Port for Express server to listen on (automatically assigned by Render, but default is 5000)
PORT=5000

# CORS Allowed Origin (points to your Vercel deployment URL to allow client requests)
# In local development: http://localhost:3000
# In production: https://your-frontend-app.vercel.app (or * to allow all)
FRONTEND_URL=http://localhost:3000

# Supabase API Details (used on the backend to create signed URLs for private images)
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_key

# Telegram Channel Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Instagram Graph API Configuration
IG_USER_ID=your_instagram_business_user_id
ACCESS_TOKEN=your_60_day_long_lived_facebook_graph_api_token
